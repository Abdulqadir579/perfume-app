<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cost &amp; Margin Comparator</title>
<style>
  :root{
    --ink:#14213d; --ink-2:#1f2d50; --paper:#faf8f4; --card:#ffffff;
    --amber:#c9842b; --amber-deep:#a86916; --line:#e7e2d8;
    --ok:#2f7d4f; --bad:#b0392c; --muted:#6b7280;
    --shadow:0 10px 30px rgba(20,33,61,.08);
  }
  *{box-sizing:border-box}
  body{
    margin:0; background:var(--paper); color:var(--ink);
    font-family:"Inter",system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:760px;margin:0 auto;padding:48px 20px 64px}
  header h1{
    font-size:1.7rem;letter-spacing:-.01em;margin:0 0 6px;font-weight:700;
  }
  header p{margin:0;color:var(--muted);font-size:.95rem;line-height:1.5}
  .eyebrow{
    font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;
    color:var(--amber-deep);font-weight:600;margin-bottom:14px
  }

  .board{
    margin-top:34px;background:var(--card);border:1px solid var(--line);
    border-radius:16px;box-shadow:var(--shadow);overflow:hidden;
  }
  .slots{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line)}
  @media(max-width:560px){.slots{grid-template-columns:1fr}}
  .slot{
    background:var(--card);padding:26px 22px;position:relative;
    transition:background .15s;
  }
  .slot.drag{background:#fbf3e6}
  .slot label{display:block;cursor:pointer}
  .slot .num{
    font-size:.72rem;font-weight:700;color:var(--amber-deep);
    letter-spacing:.1em;margin-bottom:10px
  }
  .slot h3{margin:0 0 4px;font-size:1.02rem}
  .slot .hint{font-size:.82rem;color:var(--muted);line-height:1.45;margin:0 0 16px}
  .drop{
    border:1.5px dashed var(--line);border-radius:11px;padding:20px 14px;
    text-align:center;transition:border-color .15s,background .15s
  }
  .slot:hover .drop{border-color:var(--amber)}
  .drop .ic{font-size:1.5rem;line-height:1}
  .drop .pick{color:var(--amber-deep);font-weight:600}
  .drop .sub{font-size:.74rem;color:var(--muted);margin-top:4px}
  .file{
    display:none;margin-top:14px;font-size:.84rem;
    background:#f5f1e8;border-radius:8px;padding:9px 12px;
    align-items:center;justify-content:space-between;gap:10px
  }
  .file.show{display:flex}
  .file .name{font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .file .clear{cursor:pointer;color:var(--muted);border:none;background:none;font-size:1rem;padding:0 2px}
  input[type=file]{position:absolute;width:1px;height:1px;opacity:0;overflow:hidden}

  .action{padding:22px;background:#fbfaf7;border-top:1px solid var(--line)}
  button.go{
    width:100%;border:none;border-radius:11px;padding:15px;font-size:1rem;
    font-weight:600;color:#fff;background:var(--ink);cursor:pointer;
    transition:background .15s,transform .05s;font-family:inherit
  }
  button.go:hover:not(:disabled){background:var(--ink-2)}
  button.go:active:not(:disabled){transform:translateY(1px)}
  button.go:disabled{background:#c7c9d1;cursor:not-allowed}
  button.go .spin{
    display:inline-block;width:15px;height:15px;border:2px solid rgba(255,255,255,.35);
    border-top-color:#fff;border-radius:50%;animation:sp .7s linear infinite;
    vertical-align:-2px;margin-right:8px
  }
  @keyframes sp{to{transform:rotate(360deg)}}

  .msg{margin-top:16px;border-radius:10px;padding:13px 15px;font-size:.88rem;line-height:1.45;display:none}
  .msg.show{display:block}
  .msg.err{background:#fbe9e7;color:var(--bad);border:1px solid #f3c9c4}
  .msg.ok{background:#e9f3ec;color:var(--ok);border:1px solid #c6e2cf}

  .note{margin-top:26px;font-size:.8rem;color:var(--muted);line-height:1.55}
  .note b{color:var(--ink)}
  footer{margin-top:30px;font-size:.74rem;color:#9aa0ab;text-align:center}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="eyebrow">Wholesale Pricing</div>
    <h1>Cost &amp; Margin Comparator</h1>
    <p>Drop in your inventory and the latest supplier sheet. Get back one workbook
       showing every cost change and your new margin on each product.</p>
  </header>

  <div class="board">
    <div class="slots">
      <div class="slot" id="slot-master">
        <label>
          <div class="num">FILE 1</div>
          <h3>Your inventory</h3>
          <p class="hint">Your master sheet — last cost and selling price.</p>
          <div class="drop">
            <div class="ic">📄</div>
            <div><span class="pick">Choose file</span> or drag here</div>
            <div class="sub">.xlsx</div>
          </div>
          <input type="file" id="master" accept=".xlsx,.xlsm">
        </label>
        <div class="file" id="file-master">
          <span class="name"></span><button class="clear" data-for="master">✕</button>
        </div>
      </div>

      <div class="slot" id="slot-supplier">
        <label>
          <div class="num">FILE 2</div>
          <h3>Supplier sheet</h3>
          <p class="hint">The latest sheet from your supplier — current cost.</p>
          <div class="drop">
            <div class="ic">🧾</div>
            <div><span class="pick">Choose file</span> or drag here</div>
            <div class="sub">.xlsx</div>
          </div>
          <input type="file" id="supplier" accept=".xlsx,.xlsm">
        </label>
        <div class="file" id="file-supplier">
          <span class="name"></span><button class="clear" data-for="supplier">✕</button>
        </div>
      </div>
    </div>

    <div class="action">
      <button class="go" id="go" disabled>Compare &amp; download</button>
      <div class="msg" id="msg"></div>
    </div>
  </div>

  <p class="note">
    Products are matched by <b>Barcode</b>. The result shows cost difference, old vs new
    margin, and a flag on anything selling at a loss or thin margin. Files are processed
    in the moment and never stored.
  </p>

  <footer>Runs entirely on upload — nothing is kept after your download.</footer>
</div>

<script>
const inputs = {master: document.getElementById('master'), supplier: document.getElementById('supplier')};
const go = document.getElementById('go');
const msg = document.getElementById('msg');

function refresh(){
  go.disabled = !(inputs.master.files.length && inputs.supplier.files.length);
}
function showFile(key){
  const box = document.getElementById('file-'+key);
  const f = inputs[key].files[0];
  if(f){ box.classList.add('show'); box.querySelector('.name').textContent = f.name; }
  else { box.classList.remove('show'); }
  refresh();
}
['master','supplier'].forEach(key=>{
  inputs[key].addEventListener('change',()=>{ hideMsg(); showFile(key); });
  const slot = document.getElementById('slot-'+key);
  ['dragenter','dragover'].forEach(e=>slot.addEventListener(e,ev=>{ev.preventDefault();slot.classList.add('drag')}));
  ['dragleave','drop'].forEach(e=>slot.addEventListener(e,ev=>{ev.preventDefault();slot.classList.remove('drag')}));
  slot.addEventListener('drop',ev=>{
    const f = ev.dataTransfer.files[0];
    if(f){ inputs[key].files = ev.dataTransfer.files; hideMsg(); showFile(key); }
  });
});
document.querySelectorAll('.clear').forEach(b=>b.addEventListener('click',e=>{
  e.preventDefault(); const key=b.dataset.for; inputs[key].value=''; showFile(key);
}));

function setMsg(text,type){ msg.textContent=text; msg.className='msg show '+type; }
function hideMsg(){ msg.className='msg'; }

go.addEventListener('click', async ()=>{
  hideMsg();
  go.disabled=true;
  const original=go.innerHTML;
  go.innerHTML='<span class="spin"></span>Comparing…';
  try{
    const fd=new FormData();
    fd.append('master', inputs.master.files[0]);
    fd.append('supplier', inputs.supplier.files[0]);
    const res=await fetch('/api/compare',{method:'POST',body:fd});
    if(!res.ok){
      let detail='Could not build the comparison. Please check both files and try again.';
      try{ const j=await res.json(); if(j.detail) detail=j.detail; }catch(e){}
      setMsg(detail,'err');
      return;
    }
    const blob=await res.blob();
    const cd=res.headers.get('Content-Disposition')||'';
    const m=cd.match(/filename="?([^"]+)"?/);
    const name=m?m[1]:'comparison.xlsx';
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a'); a.href=url; a.download=name; a.click();
    URL.revokeObjectURL(url);
    setMsg('Done. Your comparison workbook has downloaded.','ok');
  }catch(err){
    setMsg('Network problem — the file could not be sent. Check your connection and try again.','err');
  }finally{
    go.innerHTML=original; refresh();
  }
});
</script>
</body>
</html>
